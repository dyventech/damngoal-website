---
interface Props {
	energy?: 'good' | 'low' | 'rough';
}

const { energy = 'low' } = Astro.props;
---

<div class="today-mock" aria-hidden="true">
	<div class="today-mock__shell">
		<div class="today-mock__island"></div>
		<div class="today-mock__frame">
		<div class="today-mock__statusbar">
			<span class="today-mock__time">Today</span>
			<span class="today-mock__pill">9:41</span>
		</div>

		<div class="today-mock__energy">
			<span class="today-mock__energy-label">How are you feeling?</span>
			<div class="today-mock__energy-pills">
				<span class:list={['today-mock__energy-btn', { 'is-active': energy === 'good' }]}>Good</span>
				<span class:list={['today-mock__energy-btn', { 'is-active': energy === 'low' }]}>Low</span>
				<span class:list={['today-mock__energy-btn', { 'is-active': energy === 'rough' }]}>Rough</span>
			</div>
		</div>

		<div class="today-mock__strip">
			<span class="today-mock__strip-fill" style="width: 40%"></span>
			<span class="today-mock__strip-label">2 touched today — not a streak</span>
		</div>

		<div class="today-mock__group">
			<span class="today-mock__group-label">Morning</span>
			<div class="today-mock__item today-mock__item--done">
				<span class="today-mock__check">✓</span>
				<div>
					<span class="today-mock__item-name">Drink water after waking</span>
					<span class="today-mock__item-meta">Lighter: one sip at the sink · done</span>
				</div>
			</div>
			<div class="today-mock__item today-mock__item--active">
				<span class="today-mock__check today-mock__check--open"></span>
				<div>
					<span class="today-mock__item-name">10-minute walk</span>
					<span class="today-mock__lighter">Lighter: 5-minute walk around the block</span>
				</div>
			</div>
		</div>

		<div class="today-mock__group">
			<span class="today-mock__group-label">Afternoon</span>
			<div class="today-mock__item today-mock__item--ghost">
				<span class="today-mock__check today-mock__check--ghost"></span>
				<div>
					<span class="today-mock__item-name">30-minute deep work</span>
					<span class="today-mock__item-meta">Hidden on Low — no lighter version yet</span>
				</div>
			</div>
		</div>
		</div>
	</div>
</div>

<style>
	.today-mock {
		position: relative;
	}

	.today-mock__shell {
		position: relative;
		padding: 0.625rem;
		background: linear-gradient(145deg, #1a2744 0%, #0f1628 100%);
		border-radius: 2.75rem;
		box-shadow:
			var(--shadow-card),
			0 0 0 1px rgba(255, 255, 255, 0.08) inset,
			0 40px 80px rgba(24, 35, 63, 0.2);
	}

	.today-mock__island {
		position: absolute;
		top: 1.125rem;
		left: 50%;
		transform: translateX(-50%);
		width: 72px;
		height: 22px;
		background: #0a0f1a;
		border-radius: 999px;
		z-index: 2;
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
	}

	.today-mock__frame {
		padding: 2.75rem 1.125rem 1.25rem;
		background: linear-gradient(165deg, #ffffff 0%, #f4f7ff 100%);
		border-radius: 2.25rem;
		overflow: hidden;
	}

	.today-mock__statusbar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.25rem;
	}

	.today-mock__time {
		font-family: var(--font-display);
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--brand);
	}

	.today-mock__pill {
		padding: 0.2rem 0.55rem;
		font-size: 0.6875rem;
		font-weight: 600;
		color: var(--text-soft);
		background: rgba(217, 214, 255, 0.5);
		border-radius: 999px;
	}

	.today-mock__energy-label {
		display: block;
		margin-bottom: 0.5rem;
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--text-muted);
	}

	.today-mock__energy-pills {
		display: flex;
		gap: 0.375rem;
	}

	.today-mock__energy-btn {
		flex: 1;
		padding: 0.5rem 0.25rem;
		font-size: 0.75rem;
		font-weight: 600;
		text-align: center;
		color: var(--text-soft);
		background: rgba(24, 35, 63, 0.04);
		border-radius: 12px;
		transition: all 0.2s var(--ease-out);
	}

	.today-mock__energy-btn.is-active {
		color: var(--brand);
		background: linear-gradient(135deg, rgba(217, 214, 255, 0.9) 0%, rgba(var(--accent-rgb), 0.2) 100%);
		box-shadow: 0 2px 12px rgba(var(--accent-rgb), 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.6);
	}

	.today-mock__strip {
		position: relative;
		height: 6px;
		margin: 1.25rem 0;
		background: rgba(24, 35, 63, 0.06);
		border-radius: 999px;
		overflow: hidden;
	}

	.today-mock__strip-fill {
		display: block;
		height: 100%;
		background: linear-gradient(90deg, var(--accent) 0%, var(--accent-secondary) 100%);
		border-radius: 999px;
	}

	.today-mock__strip-label {
		display: block;
		margin-top: 0.375rem;
		font-size: 0.6875rem;
		color: var(--text-soft);
	}

	.today-mock__group {
		margin-bottom: 1rem;
	}

	.today-mock__group:last-child {
		margin-bottom: 0;
	}

	.today-mock__group-label {
		display: block;
		margin-bottom: 0.5rem;
		font-size: 0.6875rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--text-soft);
	}

	.today-mock__item {
		display: flex;
		gap: 0.75rem;
		padding: 0.75rem;
		margin-bottom: 0.5rem;
		background: rgba(245, 248, 255, 0.8);
		border-radius: 14px;
	}

	.today-mock__item--done {
		opacity: 0.7;
	}

	.today-mock__item--active {
		background: linear-gradient(135deg, rgba(217, 214, 255, 0.35) 0%, rgba(255, 255, 255, 0.9) 100%);
		border: 1px solid rgba(var(--accent-rgb), 0.25);
	}

	.today-mock__item--ghost {
		opacity: 0.45;
		border: 1px dashed rgba(24, 35, 63, 0.12);
		background: transparent;
	}

	.today-mock__check {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
		font-size: 0.6875rem;
		font-weight: 700;
		color: var(--brand);
		background: var(--celebration);
		border-radius: 50%;
	}

	.today-mock__check--open {
		background: transparent;
		border: 2px solid var(--accent);
	}

	.today-mock__check--ghost {
		background: transparent;
		border: 2px dashed rgba(24, 35, 63, 0.15);
	}

	.today-mock__item-name {
		display: block;
		font-size: 0.8125rem;
		font-weight: 600;
		color: var(--brand);
	}

	.today-mock__item-meta {
		display: block;
		margin-top: 0.125rem;
		font-size: 0.6875rem;
		color: var(--text-soft);
	}

	.today-mock__lighter {
		display: block;
		margin-top: 0.375rem;
		padding: 0.375rem 0.5rem;
		font-size: 0.6875rem;
		color: var(--brand);
		background: rgba(var(--accent-rgb), 0.12);
		border-radius: 8px;
		border-left: 3px solid var(--accent);
	}
</style>
