---
const currentPath = Astro.url.pathname;
---

<header class="landing-header">
	<div class="landing-container landing-header__inner">
		<a href="/" class="landing-header__logo">
			<img src="/damngoal-logo.png" alt="" width="36" height="36" />
			<span>Damn<span class="accent">Goal</span></span>
		</a>

		<nav class="landing-header__nav" aria-label="Main">
			<a
				href="/research"
				class:list={['landing-header__link', { 'is-active': currentPath === '/research' }]}
			>
				Research
			</a>
			<a
				href="/privacy"
				class:list={['landing-header__link', { 'is-active': currentPath === '/privacy' }]}
			>
				Privacy
			</a>
		</nav>
	</div>
</header>

<style>
	.landing-header__nav {
		display: flex;
		align-items: center;
		gap: 0.375rem;
	}

	.landing-header__link {
		padding: 0.5625rem 0.875rem;
		font-family: var(--font-family);
		font-size: 0.875rem;
		font-weight: 500;
		text-decoration: none;
		color: var(--text-muted);
		border-radius: var(--radius-full);
		transition: color 0.2s ease, background 0.2s ease;
	}

	.landing-header__link:hover {
		color: var(--brand);
		background: rgba(217, 214, 255, 0.4);
	}

	.landing-header__link.is-active {
		color: var(--brand);
		background: rgba(217, 214, 255, 0.55);
	}

	.landing-header__link:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
</style>
