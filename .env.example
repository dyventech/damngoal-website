# Brevo waitlist form — from Brevo → Forms → Share → form action URL
BREVO_FORM_ACTION=https://11d4d5e0.sibforms.com/serve/YOUR_FORM_ID

# Cloudflare Turnstile — https://dash.cloudflare.com → Turnstile → Add widget
# Site key is public (also set PUBLIC_ prefix for Astro client)
PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Alternative: Brevo Contacts API (if not using the form URL above)
# BREVO_API_KEY=your_brevo_api_key_here
# BREVO_LIST_ID=2
